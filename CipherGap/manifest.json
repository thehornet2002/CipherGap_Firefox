
{
  "manifest_version": 3,
  "name": "CipherGap",
  "version": "1.0",
  "description": "A Chrome extension providing End-to-End encryption.",

  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://web.rubika.ir/*",
    "https://web.splus.ir/*",
    "https://web.bale.ai/*",
    "https://web.eitaa.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.rubika.ir/*",
        "https://web.splus.ir/*",
        "https://web.bale.ai/*",
        "https://web.eitaa.com/*"
      ],

      "js": [
        "content/utils.js",
        "content/storage.js",
        "content/crypto.js",
        "content/packet.js",
        "content/bale.js",
        "content/messenger.js",
        "content/observer.js",
        "content/decrypt.js",
        "content/content.js"
      ]
    }
  ],

  "action": {
    "default_title": "CipherGap",
    "default_popup": "popup/popup.html"
  }
}

